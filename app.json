{
  "expo": {
    "name": "objetiva",
    "slug": "objetiva",
    "version": "11",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "objetiva",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#010100"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.allankevinscain.objetiva",
      "versionCode": 11
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-localization",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1e9e6228-2f7f-4f35-9011-f089a40044d9"
      }
    }
  }
}
